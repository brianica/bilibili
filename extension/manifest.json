{
  "manifest_version": 3,
  "name": "Bilibili Subtitle Downloader",
  "version": "1.0.0",
  "description": "Fetch subtitles and AI summary for the current Bilibili video.",
  "permissions": ["cookies", "activeTab", "storage"],
  "host_permissions": [
    "https://www.bilibili.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    }
  }
}
